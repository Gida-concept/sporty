# =============================================================================
# GameDayWire — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and must never be committed.

# =============================================================================
# External API Keys
# =============================================================================

# SerpAPI Key (required) — https://serpapi.com
# All search data: trends, SERP, news, keywords, PAA, related searches
SERPAPI_KEY=

# Groq API Key (required) — https://groq.com
# AI content generation via Llama 4 / Mixtral models
GROQ_API_KEY=

# Google Indexing API (optional) — Google Cloud Platform service account
# Speeds up article indexation in Google Search
GOOGLE_INDEXING_CLIENT_EMAIL=
GOOGLE_INDEXING_PRIVATE_KEY=
GOOGLE_SEARCH_CONSOLE_PROPERTY=

# =============================================================================
# Site Configuration
# =============================================================================

# Site URL — used for sitemap, canonical URLs, OG tags (no trailing slash)
SITE_URL=http://localhost:3000

# Site name — used in schema markup, RSS feed, and branding
SITE_NAME=GameDayWire

# Site locale — for hreflang and schema markup (default: en_US)
SITE_LOCALE=en_US

# Admin email — for alerts, notifications, and E-E-A-T signals
ADMIN_EMAIL=admin@gamedaywire.com

# =============================================================================
# Content Generation
# =============================================================================

# Number of articles generated per day (default: 2)
ARTICLES_PER_DAY=2

# UTC hours for article generation (default: 8 AM and 7 PM)
MORNING_HOUR=8
EVENING_HOUR=19

# Keyword selection thresholds
MIN_SEARCH_VOLUME=500
MAX_KEYWORD_DIFFICULTY=40
MIN_CPC=0.50

# Target countries (comma-separated ISO 3166-1 alpha-2 codes)
TARGET_COUNTRIES=US,GB,CA,AU,IE,NZ,ZA,IN

# =============================================================================
# Feature Toggles
# =============================================================================

ENABLE_AUTO_PUBLISH=true
ENABLE_CONTENT_REFRESH=true
ENABLE_LINK_REBUILD=true
ENABLE_SEO_AUDIT=true
ENABLE_NOTIFICATIONS=true

# =============================================================================
# Content Constraints
# =============================================================================

MAX_INTERNAL_LINKS=5
MAX_EXTERNAL_LINKS=3
MIN_WORD_COUNT=800
MAX_WORD_COUNT=1500
TARGET_READING_LEVEL=65

# =============================================================================
# Caching
# =============================================================================

CACHE_ENABLED=true
CACHE_TTL_HTML=86400
CACHE_TTL_API=10800
CACHE_TTL_SITEMAP=21600

# =============================================================================
# Database
# =============================================================================

# SQLite connection string (default: local dev.db)
DATABASE_URL=file:./dev.db

# =============================================================================
# Server
# =============================================================================

# Express backend port
PORT=3001

# Backend API URL for frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# Admin
# =============================================================================

# Admin token for authentication
# If omitted, a random UUID is auto-generated and displayed on server startup.
# Set this in production. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'));"
ADMIN_TOKEN=
