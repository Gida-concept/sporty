# =============================================================================
# GameDayWire — Environment Configuration
# =============================================================================
# Copy this file to backend/.env and fill in your values.
# The .env file is listed in .gitignore and must never be committed.
#
# Only secrets and startup-only configuration go here.
# Settings that are configurable through the admin UI are DB-backed and do
# not belong in this file.
# =============================================================================

# =============================================================================
# Database (Supabase PostgreSQL)
# =============================================================================

# Supabase PostgreSQL connection string
# Local development:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/gamedaywire
# Production (Supabase remote):
#   DATABASE_URL=postgresql://user:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
# For Fly.io deployment, set as a secret:
#   fly secrets set DATABASE_URL="postgresql://user:password@host:6543/postgres?sslmode=require"
DATABASE_URL=postgresql://postgres:password@localhost:5432/gamedaywire

# =============================================================================
# External API Keys
# =============================================================================

# SerpAPI Key (required) — https://serpapi.com
# All search data: trends, SERP, news, keywords, PAA, related searches
SERPAPI_KEY=

# Groq API Key (required) — https://groq.com
# AI content generation via Llama 4 / Mixtral models
GROQ_API_KEY=

# =============================================================================
# Google Indexing API (optional)
# =============================================================================

# Speeds up article indexation in Google Search
GOOGLE_INDEXING_ENABLED=false
GOOGLE_INDEXING_CLIENT_EMAIL=
GOOGLE_INDEXING_PRIVATE_KEY=

# =============================================================================
# Server
# =============================================================================

# Express backend port (default: 3001)
PORT=3001

# Node environment (development | production)
NODE_ENV=development

# Backend API URL for frontend (used during local dev)
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# Admin & Security
# =============================================================================

# Admin token for authentication
# If omitted, a random UUID is auto-generated and displayed on server startup.
# Set this in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'));"
ADMIN_TOKEN=

# Webhook secret — used to verify incoming webhook requests
WEBHOOK_SECRET=dev-webhook-secret
