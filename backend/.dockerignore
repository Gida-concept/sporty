# =============================================================================
# GameDayWire Backend — .dockerignore (Reference Copy)
# =============================================================================
# This file documents the exclusions used for Docker builds. The actual
# .dockerignore that Docker reads lives at the project root (the build
# context root). This copy serves as the source of truth — copy its
# contents to the root .dockerignore if you need to update exclusions.
#
# Docker's build context is the monorepo root, so .dockerignore must be
# at the project root (C:\Users\USCHIP\Desktop\sporty\.dockerignore).
# =============================================================================

# Dependencies
node_modules/
# npm cache dir (rarely present in build context, but excludes it if so)
.npm/

# Version control
.git/
.gitignore
.gitattributes

# Build output
dist/
.next/
out/

# Backend source (not needed in production images — we copy from build stage)
# Uncomment if you want to prevent any accidental COPY of src/:
# backend/src/

# Tests and coverage
tests/
coverage/
playwright-report/
test-results/
*.test.ts
*.spec.ts
*.test.js
*.spec.js

# Environment files (secrets must never be in a Docker layer)
.env
.env.local
.env.production
.env.*.local

# Documentation (not needed at runtime)
docs/
*.md
README.md
LICENSE

# Other workspaces (not needed for backend-only build)
frontend/
cron/
scripts/

# IDE and OS files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Cache
cache/
.turbo/
*.tsbuildinfo

# Database files (local development only)
*.db
*.db-journal

# Docker files (don't nest Docker contexts)
docker-compose*.yml
Dockerfile*
