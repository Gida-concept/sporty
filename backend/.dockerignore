# =============================================================================
# GameDayWire Backend — .dockerignore
# =============================================================================
# This file tells Docker which files to exclude from the build context.
# Apply it by placing this file at the root of the Docker build context
# (the monorepo root when building with `-f backend/Dockerfile`).
#
# To use this from the monorepo root:
#   Copy or symlink:   cp backend/.dockerignore .dockerignore
#   Or build with:     docker build -f backend/Dockerfile -t api $(cat backend/.dockerignore | while read line; do echo "--ignore $line"; done)
#
# For Fly.io, place this file at the monorepo root before deploying:
#   cp backend/.dockerignore .dockerignore
#   fly deploy --config backend/fly.toml
# =============================================================================

# Dependencies
node_modules/
.pnpm-store/
.pnpm-home/

# Version control
.git/
.gitignore
.gitattributes

# Build output
dist/
.next/
out/

# Backend source (not needed in production images — we copy from build stage)
# Uncomment if you want to prevent any accidental COPY of src/:
# backend/src/

# Tests and coverage
tests/
coverage/
playwright-report/
test-results/
*.test.ts
*.spec.ts
*.test.js
*.spec.js

# Environment files (secrets must never be in a Docker layer)
.env
.env.local
.env.production
.env.*.local

# Documentation (not needed at runtime)
docs/
*.md
README.md
LICENSE

# Other workspaces (not needed for backend-only build)
frontend/
cron/
scripts/

# IDE and OS files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Cache
cache/
.turbo/
*.tsbuildinfo

# Database files (local development only)
*.db
*.db-journal
prisma/migrations/**/migration_lock.toml

# Docker files (don't nest Docker contexts)
docker-compose*.yml
Dockerfile*
