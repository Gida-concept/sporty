# =============================================================================
# GameDayWire Backend — .dockerignore
# =============================================================================
# This file tells Docker which files to exclude from the build context.
# NOTE: Docker reads .dockerignore from the build context root (the monorepo
# root), not from the directory containing the Dockerfile. For this file to
# take effect, Docker requires a .dockerignore at the build context root.
#
# When building with:
#   docker build -f backend/Dockerfile .
#
# Docker looks for .dockerignore in the build context (the '.' directory).
# If you need build context exclusions, place a .dockerignore at the project
# root with the same contents as this file.
# =============================================================================

# Dependencies
node_modules/
.pnpm-store/
.pnpm-home/

# Version control
.git/
.gitignore
.gitattributes

# Build output
dist/
.next/
out/

# Backend source (not needed in production images — we copy from build stage)
# Uncomment if you want to prevent any accidental COPY of src/:
# backend/src/

# Tests and coverage
tests/
coverage/
playwright-report/
test-results/
*.test.ts
*.spec.ts
*.test.js
*.spec.js

# Environment files (secrets must never be in a Docker layer)
.env
.env.local
.env.production
.env.*.local

# Documentation (not needed at runtime)
docs/
*.md
README.md
LICENSE

# Other workspaces (not needed for backend-only build)
frontend/
cron/
scripts/

# IDE and OS files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Cache
cache/
.turbo/
*.tsbuildinfo

# Database files (local development only)
*.db
*.db-journal
prisma/migrations/**/migration_lock.toml

# Docker files (don't nest Docker contexts)
docker-compose*.yml
Dockerfile*
