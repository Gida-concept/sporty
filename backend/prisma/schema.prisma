generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  trends      Trend[]
  keywords    Keyword[]
  articles    ArticleCategory[]
}

model Trend {
  id              String    @id @default(uuid())
  query           String
  normalizedQuery String
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])
  searchVolume    Int?
  growthRate      Float?
  geo             String?
  relatedQueries  String?   // JSON array
  fetchedAt       DateTime  @default(now())
  processed       Boolean   @default(false)
  article         Article?
  trendScore      Float?
  articleId       String?

  @@index([categoryId])
  @@index([normalizedQuery])
  @@index([processed])
}

model Keyword {
  id              String        @id @default(uuid())
  keyword         String        @unique
  headTerm        String
  modifier        String
  searchVolume    Int?
  difficulty      Float?
  cpc             Float?
  intent          String?
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  priorityScore   Float?
  serpFeatures    String?       // JSON array
  status          String        @default("pending")
  createdAt       DateTime      @default(now())
  lastValidatedAt DateTime?
  timesTargeted   Int           @default(0)
  articles        Article[]
  contentGuides   ContentGuide[]

  @@index([categoryId])
  @@index([status])
  @@index([headTerm])
}

model Article {
  id                 String    @id @default(uuid())
  slug              String    @unique
  title             String
  metaDescription   String?
  h1                String?
  contentHtml       String?
  contentBlocks     String?   // JSON
  keywordId         String
  keyword           Keyword   @relation(fields: [keywordId], references: [id])
  trendId           String?   @unique
  trend             Trend?    @relation(fields: [trendId], references: [id])
  wordCount         Int?
  readingLevel      Float?
  schemaMarkup      String?   // JSON
  internalLinks     String?   // JSON array
  externalLinks     String?   // JSON array
  status            String    @default("draft")
  generationAttempts Int      @default(0)
  qualityScore      Float?
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastRefreshedAt   DateTime?
  pageviews         Int       @default(0)
  avgTimeOnPage     Float?
  bounceRate        Float?
  googlePosition    Int?
  imageUrl          String?
  excerpt           String?
  author            String    @default("GameDayWire Staff")
  featured          Boolean   @default(false)
  tags              String?   // JSON array of tag strings
  categories        ArticleCategory[]
  pageViews         PageView[]
  seoMetrics        SeoMetric[]
  linkGraphEntries  LinkGraph[]
  contentGuide      ContentGuide?
  @@index([status])
  @@index([publishedAt])
  @@index([keywordId])
}

model ArticleCategory {
  articleId  String
  article    Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([articleId, categoryId])
  @@index([categoryId])
}

model PageView {
  id              String   @id @default(uuid())
  articleId       String
  article         Article  @relation(fields: [articleId], references: [id])
  date            DateTime
  pageviews       Int      @default(0)
  uniqueVisitors  Int      @default(0)
  avgTimeOnPage   Float?

  @@unique([articleId, date])
  @@index([articleId])
}

model SeoMetric {
  id            String   @id @default(uuid())
  articleId     String
  article       Article  @relation(fields: [articleId], references: [id])
  googlePosition Int?
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  ctr           Float?
  avgPosition   Float?
  topQueries    String?  // JSON array
  trackedAt     DateTime @default(now())

  @@index([articleId])
}

model LinkGraph {
  id            String   @id @default(uuid())
  sourceSlug    String
  targetSlug    String
  anchorText    String?
  linkType      String
  contextSnippet String?
  articleId     String
  article       Article  @relation(fields: [articleId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([articleId])
  @@index([sourceSlug])
  @@index([targetSlug])
}

model ContentGuide {
  id              String   @id @default(uuid())
  articleId       String   @unique
  article         Article  @relation(fields: [articleId], references: [id])
  keywordId       String
  keyword         Keyword  @relation(fields: [keywordId], references: [id])
  guideData       String?  // JSON
  serpData        String?  // JSON
  narrativeAngle  String?
  dataPointsCount Int?
  contentGaps     String?  // JSON
  createdAt       DateTime @default(now())

  @@index([keywordId])
}

model SystemLog {
  id        String   @id @default(uuid())
  logType   String
  message   String
  metadata  String?  // JSON
  severity  String   @default("info")
  createdAt DateTime @default(now())

  @@index([logType])
  @@index([severity])
  @@index([createdAt])
}
