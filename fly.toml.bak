# fly.toml -- GameDayWire Backend
# Deploy: fly deploy
# Set secrets: fly secrets set SERPAPI_KEY=... GROQ_API_KEY=... ADMIN_TOKEN=... WEBHOOK_SECRET=...
# Database (Supabase PostgreSQL): fly secrets set DATABASE_URL="postgresql://user:password@host:6543/postgres?sslmode=require"

app = "gamedaywire"

[build]
  dockerfile = "Dockerfile"

[env]
  NODE_ENV = "production"
  PORT = "8080"
  # DATABASE_URL must be set via fly secrets set (Supabase PostgreSQL connection string)
  # Do NOT put the connection string in this file.

[[services]]
  internal_port = 8080
  protocol = "tcp"

  [[services.ports]]
    handlers = ["http"]
    port = 80

  [[services.ports]]
    handlers = ["tls", "http"]
    port = 443

# NOTE: No [[mounts]] section -- Supabase PostgreSQL is the database, not SQLite on a Fly Volume.
# The DATABASE_URL is set via fly secrets.
